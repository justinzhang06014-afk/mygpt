# 複製此檔案為 .env 並填入實際值。

# ── Phison 正式端點（不設定 LLM_PROVIDER 就是這個，預設分支） ──
PHISON_API_KEY=AINX-F78D2FCD53915EE37BD0871392FFBFFAF648C53C388950FC6A1F2ED8C534B249
LLM_MODEL=Qwen/Qwen3.6-35B-A3B-FP8
LLM_BASE_URL=https://ainexus.phison.com/api/external/v1

# ── 本機測試路徑：連不到 Phison 內網時，可以暫時用 Claude 代替（測完記得改回來） ──
# LLM_PROVIDER=native
# LLM_NATIVE_PROVIDER=anthropic
# LLM_MODEL=anthropic/claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=  # 不要把真的 key 寫進這個檔案本身，用 shell/docker --env-file 注入

# ── 容器建立方式 ──
# 不設定 ORCHESTRATOR_URL：這支服務自己用 docker.sock 建每個使用者的容器（需要掛
# /var/run/docker.sock，見 docker-compose.yml）。
# 有設定 ORCHESTRATOR_URL：改委派給同事的 orchestrator 服務（見 orchestrator_client.py）。
# ORCHESTRATOR_URL=http://your-orchestrator-host:port

# ── 檔案路徑 ──
PROFILES_BASE_DIR=/opt/data/profiles
DATA_ROOT=/opt/data

# 🧪 測試方便用：子容器也對外開一個隨機 port，可以直接開瀏覽器 Swagger。
# 正式環境拿掉——子容器不該直接暴露給外部。
PUBLISH_CHILD_PORTS=true

# 注意：PHISON_TOKEN（AINexus bearer token）不是全域環境變數，是透過
# POST /api/agent/{agent_id}/mcp/phison-ainexus/credentials，或聊天時 ChatRequest.phison_token
# 逐 agent／逐輪設定的。
