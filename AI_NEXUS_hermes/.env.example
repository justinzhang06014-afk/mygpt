# 環境變數範例（複製成 .env 並設定真實值）

# ============================================================
# 🚀 必要設定 - 系統需要這些才能正常運作
# ============================================================

# [1] 對方 Orchestrator 服務位址
#      你的系統會把建立容器的請求轉發到這個地方
ORCHESTRATOR_URL=http://192.168.41.173:5080

# [2] 遠端主機上的資料根目錄
#      對方 Orchestrator 會把這個路徑掛載到容器的 /data
#      例如：/home/phison/ainexus 或 /shared/nexus/agents
HERMES_DATA_ROOT=/home/phison/ainexus

# ============================================================
# 🔐 選用設定 - 根據對方 Orchestrator 配置決定是否需要
# ============================================================

# [3] External Access API Key
#      只有當對方的 Orchestrator 啟用了 ExternalAccess.Enabled=true 時需要
#      用於透過外部代理訪問容器內部服務
ORCHESTRATOR_EXTERNAL_API_KEY=change-me

# ============================================================
# 🎯 注意事項
# ============================================================

# ❌ 不需要在這裡設定的東西：
# - PHISON_API_KEY、LLM_BASE_URL、LLM_MODEL 等
# - 這些都是動態的，透過 Swagger API 傳入即可（/api/session/ensure）

# ✅ 這裡只設定「部署環境相關」的參數
# - 系統連到哪裡 (ORCHESTRATOR_URL)
# - 遠端主機的檔案路徑在哪 (HERMES_DATA_ROOT)  
# - 外部訪問的安全金鑰 (ORCHESTRATOR_EXTERNAL_API_KEY)

# 參考：你的 Swagger 請求範例
# POST /api/session/ensure
# {
#   "user_id": "demo001",
#   "llm_api_key": "AINX-...",          # ⬅️ 動態傳入，不用環境變數
#   "model": "Qwen/Qwen3.6-35B-A3B-FP8", # ⬅️ 動態傳入，不用環境變數
#   "phison_token": "eyJ...",           # ⬅️ 動態傳入，不用環境變數
#   "system_prompt": "你是一個..."      # ⬅️ 動態傳入，不用環境變數
# }